<odoo> 
    <record id="action_hola_visitante" model="ir.actions.act_window"> 
        <field name="name">Control de Visitantes</field> 
        <field name="res_model">hola.visitante</field> 
        <field name="view_mode">list,form</field> 
    </record> 
 
    <menuitem id="menu_hola_raiz" name="Recepción" sequence="10"/> 
    <menuitem id="menu_hola_visitante" name="Visitantes" parent="menu_hola_raiz" 
              action="action_hola_visitante"/> 
 
    <record id="view_visitante_form" model="ir.ui.view"> 
        <field name="name">hola.visitante.form</field> 
        <field name="model">hola.visitante</field> 
        <field name="arch" type="xml"> 
            <form> 
                <sheet> 
                    <group> 
                        <field name="name"/> 
                        <field name="fecha_visita"/> 
                        <field name="motivo"/> 
                    </group> 
                </sheet> 
            </form> 
        </field> 
    </record> 
 
    <record id="view_visitante_list" model="ir.ui.view"> 
        <field name="name">hola.visitante.list</field> 
        <field name="model">hola.visitante</field> 
        <field name="arch" type="xml"> 
            <list string="Visitantes"> 
                <field name="name"/> 
                <field name="fecha_visita"/> 
            </list> 
        </field> 
    </record> 
</odoo>